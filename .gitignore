# ==========================================
# .gitignore - PROTEGE DADOS SENSÍVEIS
# ==========================================

# Variáveis de ambiente (API keys, tokens)
.env
.env.*
!.env.example
*.env
secrets.yaml
credentials.json
api_keys.txt

# Diretório de cache (dados baixados)
cache/
.cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs (podem conter informações sensíveis)
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Arquivos de configuração local
config.local.py
config.local.json
settings.local.yaml
local_settings.py

# Configuração do Claude Desktop (pode ter caminhos locais)
claude_desktop_config.json

# Configuração antiga (não usar)
.claude/

# IDEs e editores
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini

# Python
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# Ambientes virtuais
venv/
ENV/
env/
.venv
.virtualenv

# Testes
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
pytest_debug.log

# Arquivos temporários
*.tmp
*.bak
temp/
tmp/
*.swp
*~.nib

# Arquivos de dados locais
data/
*.db
*.sqlite
*.sqlite3

# Deploy e cloud
.vercel/
.netlify/
.railway/
fly.toml.local
render-local.yaml

# Docker
*.pid
*.seed
*.pid.lock
.dockerignore.local

# Backup files
*.backup
*.orig
